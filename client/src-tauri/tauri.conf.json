{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "SocialNetworking",
    "copyright": "2025 Bonchi \u2014 Built on Mobium",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "identifier": "com.bonchi.app",
  "productName": "Bonchi",
  "version": "0.3.0",
  "plugins": {
    "shell": {
      "open": "^https://"
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self' https://tauri.localhost; connect-src 'self' wss://* ws://localhost:* ws://127.0.0.1:*; img-src 'self' data: blob:; media-src 'self' blob: mediastream:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; frame-src 'none'; object-src 'none'; base-uri 'self'"
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Bonchi",
        "width": 1200
      }
    ],
    "withGlobalTauri": true
  }
}